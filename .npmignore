# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output/

# ESLint cache
.eslintcache

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test
.env.production

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Development and test files
test/
scripts/
*.test.ts
*.test.js
.test-env
tsconfig*.json
*.tsbuildinfo

# Lockfiles (libraries should not ship with lockfiles)
pnpm-lock.yaml
package-lock.json
yarn.lock

# Proto files should be excluded from root
proto/

# Ignore non-.proto files in dist/proto/
dist/proto/opentelemetry/**
!dist/proto/**/*.proto

# Source files should be excluded from published package
src/

# Ignore development files
.tshy
.claude
.github
